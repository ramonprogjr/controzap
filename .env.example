# Copie para .env e preencha. Não commite o .env.

# ============== Supabase (obrigatório) ==============
# Projeto produção ALS/finy: https://supabase.com/dashboard/project/ncvwocdinqudlgivnmpz
# NEXT_PUBLIC_SUPABASE_URL=https://ncvwocdinqudlgivnmpz.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   (Settings → API → anon public)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...       (Settings → API → service_role — NUNCA no frontend)

# ============== URL pública (links de login/credenciais) ==============
# Desenvolvimento local:
# NEXT_PUBLIC_APP_URL=http://localhost:3003
# Domínio .br (ex.: smartvendas.com.br): defina no Render em Environment e associe em Settings → Custom Domains.
# No registrador BR, crie CNAME apontando para o hostname que o Render mostrar (ex.: seu-app.onrender.com).
# NEXT_PUBLIC_APP_URL=https://smartvendas.com.br
#
# Copiloto / IA no servidor (Render): copie a MESMA chave válida do .env local — o painel não lê o .env do PC.
# MISTRAL_API_KEY=...   ou   AI_API_KEY=...   (se ambas existirem, AI_API_KEY ganha)

# ============== Redis (cache – lista de conversas, detalhe do chat, webhook) ==============
# Para o cache estar ativo, USE_REDIS deve ser true e REDIS_URL (ou REDIS_HOST) preenchido.
# No Redis Cloud: pegue a URL em "Connect" / "Public endpoint" (ex: redis://default:senha@host:port).

USE_REDIS=true
REDIS_URL=redis://default:SUA_SENHA@seu-host.redislabs.com:12345

# Alternativa: usar host/porta separados
# REDIS_HOST=seu-host.redislabs.com
# REDIS_PORT=12345
# REDIS_USERNAME=default
# REDIS_PASSWORD=SUA_SENHA

# ============== Histórico UAZ (sync por chat / Contatos) ==============
# O app roda a sincronização de histórico no MESMO processo (sem HTTP para si mesmo) — no Render não
# precisa de APP_URL nem INTERNAL_SYNC_SECRET para o botão Sincronizar em Contatos ou ENABLE_SYNC_HISTORY_ON_CONNECT.
#
# INTERNAL_SYNC_SECRET — opcional. Só para quem quiser chamar POST /api/channels/[id]/sync-history de fora
# (cron, outro serviço) com header X-Internal-Sync-Secret. Rotas autenticadas pelo painel não usam isso.
# INTERNAL_SYNC_SECRET=
#
# APP_URL / NEXT_PUBLIC_APP_URL — usados em links no app (login, e-mails, webhook UAZAPI, etc.).
# NEXT_PUBLIC_APP_URL=https://seu-dominio.com.br
#
# Desenvolvimento local: localhost NÃO recebe webhooks da UAZAPI (mensagens de outro celular não aparecem sozinhas).
# Use ngrok/Cloudflare Tunnel, defina NEXT_PUBLIC_APP_URL=https://SEU-TUNEL.ngrok.app e reconfigure o webhook em Conexões.
# Alternativa: botão "Carregar mais" no chat ou polling automático em NODE_ENV=development.
#
# Máx. de mensagens de TEXTO por chat em cada sync (mídias não contam nem são importadas no sync em massa). Padrão: 200.
# SYNC_HISTORY_MAX_MESSAGES_PER_CHAT=200
#
# Teto de mensagens inseridas numa única passada (soma de todos os chats). O padrão cobre ~100+ chats com histórico completo.
# SYNC_HISTORY_MAX_TOTAL_MESSAGES=50000
#
# Ao reconectar o WhatsApp (webhook connection/connected), ressincroniza chats e mensagens novas. Desligado se omitido.
# ENABLE_SYNC_HISTORY_ON_CONNECT=true

# ============== Importação em massa de contatos (POST /api/contacts/bulk-add) ==============
# A API já retenta /contact/add da UAZAPI até 3x em erros transitórios (ex.: internal-server-error).
# Se true/1: após esgotar retentativas, grava o contato só na plataforma (channel_contacts), sem falhar a linha.
# BULK_ADD_PLATFORM_ONLY_FALLBACK=false

# ============== IA (Mistral — copiloto, sugestões, respostas rápidas, descrições) ==============

# Chave em https://console.mistral.ai (API keys). Alternativa: MISTRAL_API_KEY ou typo MISTARL_API_KEY.
# IMPORTANTE: se preencheres AI_API_KEY e MISTRAL_API_KEY, o app usa SEMPRE AI_API_KEY primeiro.
# Para evitar 401 “misteriosos”, usa só uma delas (ou apaga a que estiver vazia/antiga).
AI_API_KEY=

# Base da API (padrão do app se omitido: https://api.mistral.ai/v1)
AI_BASE_URL=https://api.mistral.ai/v1

# Modelo (chat/completions). Ex.: mistral-small-latest, ministral-3b-latest, mistral-medium-latest
AI_MODEL=mistral-small-latest

# Opcional: mesmo efeito que AI_* acima
# MISTRAL_API_KEY=
# MISTRAL_MODEL=mistral-small-latest

# Copiloto: agente Mistral (Conversations API). Opcional se copilot_mistral_config estiver na tabela companies.
# MISTRAL_COPILOT_AGENT_ID=ag_xxxxxxxx
# MISTRAL_COPILOT_AGENT_VERSION=0

# ============== Cora (emissão de boletos – Super Admin) ==============
# Integração Direta (produção): client_id + certificado + private key
# Parceria: client_id + client_secret
# Credenciais em: CoraWeb/app > Conta > Integrações via APIs
#
# Produção (Integração Direta):
# CORA_CLIENT_ID=int-1ZVwf7iYC106q3iRWEmyJP
# CORA_API_URL=https://api.cora.com.br
# CORA_TOKEN_URL=https://matls-clients.api.cora.com.br
# CORA_CERT_PEM=<conteúdo certificate.pem, use \n para quebras ou base64>
# CORA_PRIVATE_KEY_PEM=<conteúdo private-key.key, use \n para quebras ou base64>
#
# Parceria (alternativa):
# CORA_CLIENT_ID=
# CORA_CLIENT_SECRET=
# CORA_API_URL=https://api.cora.com.br

# ============== Next.js / Windows (EBUSY em .next no OneDrive) ==============
# distDir SÓ pode ser subpasta do projeto (ex.: .next-local). Não use AppData/pastas fora do repo —
# o dev server quebra (Cannot find module react/jsx-runtime).
# Para EBUSY: mover o projeto fora do OneDrive, pausar sync, ou excluir a pasta .next do backup OneDrive.
# NEXT_DIST_DIR=.next-local

# ============== UAZAPI (Conexões / WhatsApp) ==============
# UAZAPI_BASE_URL=https://controlzap.uazapi.com
# UAZAPI_ADMIN_TOKEN=   (painel UAZ — NUNCA commitar)
# UAZAPI_WEBHOOK_SECRET=gerar-string-longa-aleatoria  (produção: ?secret= na URL do webhook)

# ============== Recuperação de senha do proprietário (WhatsApp) — desligado por padrão ==============
# Para reativar o fluxo legado (API + WhatsApp): defina true no Render.
# ENABLE_OWNER_WHATSAPP_PASSWORD_RESET=true
# FINY_PASSWORD_RESET_UAZAPI_TOKEN=   (instância UAZ só para disparo)
# PASSWORD_RESET_CODE_SECRET=           (opcional; senão usa SUPABASE_SERVICE_ROLE_KEY)
#
# Webhook opcional instância reset: UAZ_RESET_WEBHOOK_SECRET, rota /api/webhook/uaz-reset
# UAZAPI_RESET_BASE_URL=  UAZAPI_RESET_INSTANCE_TOKEN=

# ============== Render / produção ==============
# NODE_ENV=production
# REDIS_NAMESPACE=production
# CRON_SECRET=gerar-string-longa-aleatoria
# UAZAPI_WEBHOOK_SECRET=gerar-string-longa-aleatoria
# (obrigatório em produção: POST /api/webhook/uazapi exige ?secret= ou header x-uazapi-webhook-secret)
# Deploy: docs/deploy-render.md | Segurança trial: docs/security-trial-15d.md
